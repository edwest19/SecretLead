<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SecretLead.BrowsePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SecretLead"
    xmlns:vm="using:SecretLead.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    KeyDown="Page_KeyDown">

    <!--
        Browse/list screen — the app's home content. Four sections:
        1. File nav — switch entities (only ones with an actual .txt show
           up at all — existence-of-file is the whole mechanism).
        2. Category nav — steps through distinct values of the tag file's
           first tag. The record list only ever shows the selected value.
        3. Search — filters within that category by the second tag.
        4. Records — cards showing only the first two tags; Add/Edit pop an
           overlay with as few active buttons as possible.
    -->
    <Grid Padding="32">
        <!-- Empty state -->
        <StackPanel
            Spacing="8"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{x:Bind Collapsed(ViewModel.HasEntities), Mode=OneWay}">
            <TextBlock Text="No entities yet." Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
            <TextBlock
                Text="Use Import (left) to bring in a CSV and a tag file."
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Main content -->
        <Grid Visibility="{x:Bind Visible(ViewModel.HasEntities), Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 1. File nav -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock
                        Text="CURRENT FILE"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.SelectedEntityName, Mode=OneWay}"
                        Style="{StaticResource TitleTextBlockStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
                    <ComboBox
                        HorizontalAlignment="Right"
                        ItemsSource="{x:Bind ViewModel.EntityNames, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedEntityName, Mode=TwoWay}"
                        MinWidth="180" />
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button
                            Content="Export"
                            Command="{x:Bind ViewModel.ExportCommand}"
                            IsEnabled="{x:Bind ViewModel.CanExportOrPrint, Mode=OneWay}" />
                        <Button
                            Content="Print"
                            Command="{x:Bind ViewModel.PrintCommand}"
                            IsEnabled="{x:Bind ViewModel.CanExportOrPrint, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- 2. Category nav -->
            <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,16">
                <TextBlock
                    Text="{x:Bind ViewModel.CategoryTagLabel, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.CategoryPositionText, Mode=OneWay}"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <Button Content="«« First" Command="{x:Bind ViewModel.FirstCategoryCommand}" IsEnabled="{x:Bind ViewModel.CanGoToFirstOrPrevious, Mode=OneWay}" />
                        <Button Content="‹ Prev" Command="{x:Bind ViewModel.PreviousCategoryCommand}" IsEnabled="{x:Bind ViewModel.CanGoToFirstOrPrevious, Mode=OneWay}" />
                        <Button Content="Next ›" Command="{x:Bind ViewModel.NextCategoryCommand}" IsEnabled="{x:Bind ViewModel.CanGoToNextOrLast, Mode=OneWay}" />
                        <Button Content="Last »»" Command="{x:Bind ViewModel.LastCategoryCommand}" IsEnabled="{x:Bind ViewModel.CanGoToNextOrLast, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- 3. Search + Add -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    Grid.Column="0"
                    MaxWidth="360"
                    HorizontalAlignment="Left"
                    PlaceholderText="{x:Bind SearchPlaceholder(ViewModel.NicknameTagLabel), Mode=OneWay}"
                    Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Grid.Column="1"
                    Content="+ Add Record"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.AddRecordCommand}" />
            </Grid>

            <!-- 4. Records -->
            <ListView
                Grid.Row="3"
                ItemsSource="{x:Bind ViewModel.Records}"
                SelectionChanged="RecordsList_SelectionChanged"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:RecordSummary">
                        <Border
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12"
                            Margin="0,4"
                            HorizontalAlignment="Stretch">
                            <StackPanel Spacing="2">
                                <TextBlock
                                    Text="{x:Bind CategoryValue}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind NicknameValue}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Detail overlay: read-only, Close / Delete / Edit -->
        <Border
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Width="340"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1,0,0,0"
            Visibility="{x:Bind Visible(ViewModel.IsDetailOpen), Mode=OneWay}">
            <Grid Padding="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Text="{x:Bind ViewModel.SelectedRecordTitle, Mode=OneWay}"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    TextWrapping="Wrap"
                    Margin="0,0,0,12" />
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.DetailFields, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TagValue">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock
                                        Text="{x:Bind TagName}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind Value}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                    <Button Content="Close" Command="{x:Bind ViewModel.CloseDetailCommand}" />
                    <Button Content="Delete" Command="{x:Bind ViewModel.DeleteRecordCommand}" />
                    <Button Content="Edit" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.EditRecordCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Editor overlay: Edit and Add share this. OK and Cancel are
             always there (Cancel and Escape — see Page_KeyDown — both close
             without saving); Clear only shows for Add. -->
        <Border
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Width="340"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1,0,0,0"
            Visibility="{x:Bind Visible(ViewModel.IsEditorOpen), Mode=OneWay}">
            <Grid Padding="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Text="{x:Bind ViewModel.EditorTitle, Mode=OneWay}"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="0,0,0,12" />
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.EditableFields}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:EditableTagValue">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock
                                        Text="{x:Bind TagName}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBox Text="{x:Bind Value, Mode=TwoWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock
                    Grid.Row="2"
                    Text="{x:Bind ViewModel.ValidationMessage, Mode=OneWay}"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    TextWrapping="Wrap"
                    Margin="0,4,0,0" />
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                    <Button Content="OK" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.SaveEditorCommand}" />
                    <Button
                        Content="Clear"
                        Command="{x:Bind ViewModel.ClearAddFormCommand}"
                        Visibility="{x:Bind Visible(ViewModel.IsAddingRecord), Mode=OneWay}" />
                    <Button Content="Cancel" Command="{x:Bind ViewModel.CancelEditorCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

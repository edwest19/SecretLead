<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SecretLead.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SecretLead"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        App shell: a fixed-width nav rail (Import / Backup / Exit) on the
        left, and a content frame on the right that later steps will
        navigate the browse/list page, Import page, etc. into. Layout is
        loosely based on the mockup's left rail + main pane split — treated
        as a visual reference, not a pixel spec.
    -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Nav rail -->
        <Grid
            Grid.Column="0"
            Padding="16"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Actions -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock
                    Text="ACTIONS"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="4,0,0,8" />

                <Button
                    Click="ImportButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE896;" FontSize="16" />
                        <TextBlock Text="Import" />
                    </StackPanel>
                </Button>
                <TextBlock
                    Text="Pick the two input files to load"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    Margin="4,2,4,16" />

                <Button
                    Click="BrowseButton_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8A9;" FontSize="16" />
                        <TextBlock Text="Browse" />
                    </StackPanel>
                </Button>
                <TextBlock
                    Text="Back to the record list"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    Margin="4,2,4,16" />

                <Button
                    Command="{x:Bind ViewModel.BackupCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE898;" FontSize="16" />
                        <TextBlock Text="Backup" />
                    </StackPanel>
                </Button>
                <TextBlock
                    Text="Copy .txt &amp; .md from AppData to a folder you choose"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    Margin="4,2,4,16" />

                <!--
                    Status area (README.md §3): validation messages and
                    errors live behind this button, not in a box that's
                    permanently visible on whatever screen is active.
                -->
                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE946;" FontSize="16" />
                        <TextBlock Text="Status" />
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout Placement="Right">
                            <StackPanel Spacing="8" MinWidth="260" MaxWidth="360">
                                <TextBlock Text="Status" Style="{StaticResource BaseTextBlockStyle}" />
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Status.Messages, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <TextBlock Text="{x:Bind}" TextWrapping="Wrap" Margin="0,2" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <!-- Exit, pinned to the bottom of the rail -->
            <Button
                Grid.Row="2"
                Command="{x:Bind ViewModel.ExitCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Background="Transparent">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE7E8;" FontSize="14" />
                    <TextBlock Text="Exit" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Content pane: BrowsePage is navigated in by default (see
             MainPage.xaml.cs), so this Frame always has something in it. -->
        <Grid Grid.Column="1">
            <Frame x:Name="ContentFrame" />
        </Grid>
    </Grid>
</Page>
